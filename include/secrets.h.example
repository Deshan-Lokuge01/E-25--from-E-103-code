#pragma once

// Template for include/secrets.h — copy this file to include/secrets.h and
// fill in real values. include/secrets.h is gitignored and must never be
// committed.

#define WIFI_SSID     "YOUR_WIFI_SSID"
#define WIFI_PASSWORD "YOUR_WIFI_PASSWORD"

// Unique ThingsBoard device access token — one per physical device
// (E-25 / E-69 / E-103 / E-94 each need their own).
#define TOKEN "YOUR_THINGSBOARD_DEVICE_TOKEN"

// OTA update password. Use a value independent of WIFI_PASSWORD so a leak
// of one credential doesn't also grant firmware-update access.
#define OTA_PASSWORD "YOUR_OTA_PASSWORD"
